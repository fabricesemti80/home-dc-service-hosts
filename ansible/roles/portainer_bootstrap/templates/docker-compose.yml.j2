name: portainer

services:
{% if portainer_is_server | bool %}
  portainer:
    image: portainer/portainer-{{ portainer_edition }}:{{ portainer_tag }}
    container_name: portainer
    restart: always
    command:
      - --admin-password-file
      - /run/secrets/portainer_admin_password
      - --trusted-origins
      - {{ portainer_hostname }}
    ports:
      - "{{ portainer_http_port }}:9000"
      - "{{ portainer_https_port }}:9443"
      - "{{ portainer_edge_port }}:8000"
    networks:
      - proxy
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{ portainer_data_dir }}:/data
      - {{ portainer_secrets_dir }}/admin_password:/run/secrets/portainer_admin_password:ro
    labels:
      docktail.service.enable: "true"
      docktail.service.name: portainer
      docktail.service.port: "9000"
      docktail.service.service-port: "443"
      docktail.service.protocol: http
      homepage.group: Infrastructure
      homepage.name: Portainer
      homepage.icon: portainer
      homepage.href: https://{{ portainer_hostname }}
{% endif %}

{% if portainer_is_agent | bool %}
  portainer-agent:
    image: portainer/agent:{{ portainer_tag }}
    container_name: portainer-agent
    restart: always
    ports:
      - "{{ portainer_agent_port }}:9001"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /var/lib/docker/volumes:/var/lib/docker/volumes
{% endif %}

networks:
  proxy:
    name: homelab_proxy
    external: true
