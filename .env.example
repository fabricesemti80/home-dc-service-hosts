# Copy to .env and fill from Doppler or an existing local tfvars source.

export TF_VAR_proxmox_endpoint="https://10.0.40.15:8006"
export TF_VAR_proxmox_insecure="true"
export TF_VAR_proxmox_username="root@pam"
export TF_VAR_proxmox_password="replace-me"
export TF_VAR_root_ssh_public_keys='["ssh-rsa replace-me"]'
export ANSI_ROOT_PASSWORD="replace-me"
export TAILSCALE_AUTHKEY="replace-me"
export TAILSCALE_OAUTH_CLIENT_ID="replace-me"
export TAILSCALE_OAUTH_CLIENT_SECRET="replace-me"
export TAILSCALE_TAILNET="koala-dominant.ts.net"
export TF_VAR_tailscale_oauth_client_id="${TAILSCALE_OAUTH_CLIENT_ID}"
export TF_VAR_tailscale_oauth_client_secret="${TAILSCALE_OAUTH_CLIENT_SECRET}"
export TF_VAR_tailscale_tailnet="${TAILSCALE_TAILNET}"
export TECHNITIUM_ADMIN_PASSWORD="replace-me"
export VAULTWARDEN_APP_URL="https://vaultwarden.koala-dominant.ts.net"
export VAULTWARDEN_ADMIN_TOKEN="replace-me"
export ARCANE_APP_URL="https://arcane.koala-dominant.ts.net"
export ARCANE_ENCRYPTION_KEY="replace-me"
export ARCANE_JWT_SECRET="replace-me"
export KESTRA_HOSTNAME="kestra.koala-dominant.ts.net"
export BESZEL_APP_URL="https://beszel.koala-dominant.ts.net"
export BESZEL_AGENT_KEY="replace-me"
export PORTAINER_ADMIN_PASSWORD="replace-me"
export PORTAINER_BE_LICENSE=""  # leave empty for CE; set to enable BE
